{
    "configurations": [
        {
            "name": "Python Debugger: Main File",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "(Windows) Launch MinGW/GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/SignalSim/bin/JsonObsGen.exe",
            "args": [
                "..\\output\\SignalSimInput.json"
            ],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/SignalSim/",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\mingw64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Make SignalSim"
        }
    ]
}